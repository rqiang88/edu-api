{
   "compilerOptions": {
      "lib": [
         "es5",
         "es6"
      ],
      "target": "es6",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./build",
      "baseUrl": ".",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": false,
      "paths": {
         "@/*": ["./src/*"],
         "@modules/*": ["./src/modules/*.ts"],
         "@entities/*": ["./src/entities/*.ts"]
      }
   }
}